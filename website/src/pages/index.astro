---
import '../styles/global.css'

const GITHUB = 'https://github.com/everydev1618/govega'
const BASE = import.meta.env.BASE_URL

const features = [
  {
    icon: `<svg class="w-6 h-6" fill="none" stroke="currentColor" stroke-width="1.5" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" d="M20.25 8.511c.884.284 1.5 1.128 1.5 2.097v4.286c0 1.136-.847 2.1-1.98 2.193-.34.027-.68.052-1.02.072v3.091l-3-3c-1.354 0-2.694-.055-4.02-.163a2.115 2.115 0 01-.825-.242m9.345-8.334a2.126 2.126 0 00-.476-.095 48.64 48.64 0 00-8.048 0c-1.131.094-1.976 1.057-1.976 2.192v4.286c0 .837.46 1.58 1.155 1.951m9.345-8.334V6.637c0-1.621-1.152-3.026-2.76-3.235A48.455 48.455 0 0011.25 3c-2.115 0-4.198.137-6.24.402-1.608.209-2.76 1.614-2.76 3.235v6.226c0 1.621 1.152 3.026 2.76 3.235.577.075 1.157.14 1.74.194V21l4.155-4.155" /></svg>`,
    title: 'Chat to build',
    desc: 'Tell Iris what you need. She delegates to Hera, who builds agents, teams, and channels on the fly. No code required.',
    color: 'text-violet-400',
  },
  {
    icon: `<svg class="w-6 h-6" fill="none" stroke="currentColor" stroke-width="1.5" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" d="M9.594 3.94c.09-.542.56-.94 1.11-.94h2.593c.55 0 1.02.398 1.11.94l.213 1.281c.063.374.313.686.645.87.074.04.147.083.22.127.325.196.72.257 1.075.124l1.217-.456a1.125 1.125 0 011.37.49l1.296 2.247a1.125 1.125 0 01-.26 1.431l-1.003.827c-.293.241-.438.613-.43.992a7.723 7.723 0 010 .255c-.008.378.137.75.43.991l1.004.827c.424.35.534.955.26 1.43l-1.298 2.247a1.125 1.125 0 01-1.369.491l-1.217-.456c-.355-.133-.75-.072-1.076.124a6.47 6.47 0 01-.22.128c-.331.183-.581.495-.644.869l-.213 1.281c-.09.543-.56.94-1.11.94h-2.594c-.55 0-1.019-.398-1.11-.94l-.213-1.281c-.062-.374-.312-.686-.644-.87a6.52 6.52 0 01-.22-.127c-.325-.196-.72-.257-1.076-.124l-1.217.456a1.125 1.125 0 01-1.369-.49l-1.297-2.247a1.125 1.125 0 01.26-1.431l1.004-.827c.292-.24.437-.613.43-.991a6.932 6.932 0 010-.255c.007-.38-.138-.751-.43-.992l-1.004-.827a1.125 1.125 0 01-.26-1.43l1.297-2.247a1.125 1.125 0 011.37-.491l1.216.456c.356.133.751.072 1.076-.124.072-.044.146-.086.22-.128.332-.183.582-.495.644-.869l.214-1.28z" /><path stroke-linecap="round" stroke-linejoin="round" d="M15 12a3 3 0 11-6 0 3 3 0 016 0z" /></svg>`,
    title: '850+ integrations',
    desc: 'Connect Composio, Slack, GitHub, Gmail, and more via MCP. Add new services at runtime through chat.',
    color: 'text-cyan-400',
  },
  {
    icon: `<svg class="w-6 h-6" fill="none" stroke="currentColor" stroke-width="1.5" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" d="M16.023 9.348h4.992v-.001M2.985 19.644v-4.992m0 0h4.992m-4.993 0l3.181 3.183a8.25 8.25 0 0013.803-3.7M4.031 9.865a8.25 8.25 0 0113.803-3.7l3.181 3.182" /></svg>`,
    title: 'Fault-tolerant',
    desc: 'Erlang-style supervision trees. Processes restart automatically. Errors are classified and retried with backoff.',
    color: 'text-emerald-400',
  },
  {
    icon: `<svg class="w-6 h-6" fill="none" stroke="currentColor" stroke-width="1.5" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" d="M18 18.72a9.094 9.094 0 003.741-.479 3 3 0 00-4.682-2.72m.94 3.198l.001.031c0 .225-.012.447-.037.666A11.944 11.944 0 0112 21c-2.17 0-4.207-.576-5.963-1.584A6.062 6.062 0 016 18.719m12 0a5.971 5.971 0 00-.941-3.197m0 0A5.995 5.995 0 0012 12.75a5.995 5.995 0 00-5.058 2.772m0 0a3 3 0 00-4.681 2.72 8.986 8.986 0 003.74.477m.94-3.197a5.971 5.971 0 00-.94 3.197M15 6.75a3 3 0 11-6 0 3 3 0 016 0zm6 3a2.25 2.25 0 11-4.5 0 2.25 2.25 0 014.5 0zm-13.5 0a2.25 2.25 0 11-4.5 0 2.25 2.25 0 014.5 0z" /></svg>`,
    title: 'Teams & channels',
    desc: 'Agents organize into teams with leads and members. Team channels provide transparent collaboration the user can watch.',
    color: 'text-amber-400',
  },
  {
    icon: `<svg class="w-6 h-6" fill="none" stroke="currentColor" stroke-width="1.5" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" d="M3.75 6A2.25 2.25 0 016 3.75h2.25A2.25 2.25 0 0110.5 6v2.25a2.25 2.25 0 01-2.25 2.25H6a2.25 2.25 0 01-2.25-2.25V6zM3.75 15.75A2.25 2.25 0 016 13.5h2.25a2.25 2.25 0 012.25 2.25V18a2.25 2.25 0 01-2.25 2.25H6A2.25 2.25 0 013.75 18v-2.25zM13.5 6a2.25 2.25 0 012.25-2.25H18A2.25 2.25 0 0120.25 6v2.25A2.25 2.25 0 0118 10.5h-2.25a2.25 2.25 0 01-2.25-2.25V6zM13.5 15.75a2.25 2.25 0 012.25-2.25H18a2.25 2.25 0 012.25 2.25V18A2.25 2.25 0 0118 20.25h-2.25A2.25 2.25 0 0113.5 18v-2.25z" /></svg>`,
    title: 'YAML DSL',
    desc: 'Define multi-agent workflows in YAML with if/else, for-each, parallel, and try/catch. No programming required.',
    color: 'text-rose-400',
  },
  {
    icon: `<svg class="w-6 h-6" fill="none" stroke="currentColor" stroke-width="1.5" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" d="M3.75 13.5l10.5-11.25L12 10.5h8.25L9.75 21.75 12 13.5H3.75z" /></svg>`,
    title: 'Real-time streaming',
    desc: 'Token-by-token SSE streaming with live tool call indicators. Built-in REST API and web dashboard.',
    color: 'text-indigo-400',
  },
]

const howItWorks = [
  {
    step: '01',
    title: 'You talk to Iris',
    desc: 'Iris is your chief of staff. Tell her what you need done. She understands your goals and figures out who should do the work.',
  },
  {
    step: '02',
    title: 'Hera builds the team',
    desc: 'Need a new capability? Hera creates agents on the fly with the right tools, personality, and team structure. No restart needed.',
  },
  {
    step: '03',
    title: 'Agents collaborate',
    desc: 'Team leads delegate to members. Agents post updates to channels. You watch it happen in real time through the dashboard.',
  },
  {
    step: '04',
    title: 'Everything persists',
    desc: 'Agents, conversations, memory, and MCP connections survive restarts. Your AI workforce is always ready.',
  },
]
---

<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1.0" />
  <title>Vega - AI agent orchestration framework</title>
  <meta name="description" content="Build reliable AI agent teams with fault-tolerant orchestration, 850+ integrations, and a Slack-like dashboard. Go library + YAML DSL." />
  <link rel="icon" href="data:image/svg+xml,<svg xmlns='http://www.w3.org/2000/svg' viewBox='0 0 100 100'><text y='.9em' font-size='90'>&#9733;</text></svg>" />
  <meta property="og:title" content="Vega - AI agent orchestration framework" />
  <meta property="og:description" content="Build reliable AI agent teams with fault-tolerant orchestration, 850+ integrations, and a Slack-like dashboard." />
  <meta property="og:type" content="website" />
  <meta property="og:url" content="https://v3ga.dev" />
</head>

<body class="antialiased">

  <!-- Nav -->
  <header class="sticky top-0 z-50 border-b border-zinc-800/50 bg-[#09090b]/80 backdrop-blur-md">
    <div class="max-w-6xl mx-auto px-6 h-16 flex items-center justify-between">
      <a href={BASE} class="flex items-center gap-2.5">
        <span class="text-amber-400 text-lg">&#9733;</span>
        <span class="font-mono font-semibold text-sm gradient-text">Vega</span>
        <span class="text-[10px] font-mono text-zinc-500 border border-zinc-800 rounded px-1.5 py-0.5">v0.4</span>
      </a>
      <nav class="hidden md:flex items-center gap-8 text-sm text-zinc-400">
        <a href="#features" class="hover:text-white transition-colors">Features</a>
        <a href="#how-it-works" class="hover:text-white transition-colors">How it works</a>
        <a href="#quickstart" class="hover:text-white transition-colors">Quick start</a>
        <a href={`${BASE}getting-started`} class="hover:text-white transition-colors">Docs</a>
      </nav>
      <div class="flex items-center gap-3">
        <a href={GITHUB} target="_blank" class="text-zinc-400 hover:text-white transition-colors">
          <svg class="w-5 h-5" fill="currentColor" viewBox="0 0 24 24">
            <path d="M12 2C6.477 2 2 6.484 2 12.017c0 4.425 2.865 8.18 6.839 9.504.5.092.682-.217.682-.483 0-.237-.008-.868-.013-1.703-2.782.605-3.369-1.343-3.369-1.343-.454-1.158-1.11-1.466-1.11-1.466-.908-.62.069-.608.069-.608 1.003.07 1.531 1.032 1.531 1.032.892 1.53 2.341 1.088 2.91.832.092-.647.35-1.088.636-1.338-2.22-.253-4.555-1.113-4.555-4.951 0-1.093.39-1.988 1.029-2.688-.103-.253-.446-1.272.098-2.65 0 0 .84-.27 2.75 1.026A9.564 9.564 0 0112 6.844c.85.004 1.705.115 2.504.337 1.909-1.296 2.747-1.027 2.747-1.027.546 1.379.202 2.398.1 2.651.64.7 1.028 1.595 1.028 2.688 0 3.848-2.339 4.695-4.566 4.943.359.309.678.92.678 1.855 0 1.338-.012 2.419-.012 2.747 0 .268.18.58.688.482A10.019 10.019 0 0022 12.017C22 6.484 17.522 2 12 2z"/>
          </svg>
        </a>
        <a href={`${BASE}getting-started`} class="btn-primary text-xs px-4 py-2">Get started</a>
      </div>
    </div>
  </header>

  <!-- Hero -->
  <section class="relative overflow-hidden grid-bg">
    <div class="hero-glow"></div>
    <div class="max-w-6xl mx-auto px-6 pt-28 pb-24 relative">
      <div class="max-w-3xl mx-auto text-center">
        <p class="inline-block text-xs font-mono text-indigo-400 border border-indigo-500/30 rounded-full px-4 py-1.5 mb-8 bg-indigo-500/5">
          Open source &middot; Go library &middot; YAML DSL &middot; MIT License
        </p>

        <h1 class="text-5xl md:text-6xl lg:text-7xl font-bold tracking-tight mb-6 leading-[1.1]">
          Build AI agent teams<br/>
          <span class="gradient-text">that actually work</span>
        </h1>

        <p class="text-lg md:text-xl text-zinc-400 mb-10 max-w-2xl mx-auto leading-relaxed">
          Vega is a fault-tolerant orchestration framework for AI agents.
          Erlang-style supervision, 850+ integrations via MCP, and a
          Slack-like dashboard where you watch your agents collaborate.
        </p>

        <div class="flex items-center justify-center gap-4 flex-wrap mb-16">
          <a href={`${BASE}getting-started`} class="btn-primary">
            Get started
          </a>
          <a href={GITHUB} target="_blank" class="btn-secondary">
            View on GitHub
          </a>
        </div>

        <!-- Install snippet -->
        <div class="max-w-lg mx-auto">
          <div class="code-block text-left text-sm glow-sm">
            <div class="flex items-center justify-between mb-3">
              <span class="text-zinc-500 text-xs font-mono">Install</span>
              <div class="flex gap-1.5">
                <span class="w-2.5 h-2.5 rounded-full bg-zinc-700"></span>
                <span class="w-2.5 h-2.5 rounded-full bg-zinc-700"></span>
                <span class="w-2.5 h-2.5 rounded-full bg-zinc-700"></span>
              </div>
            </div>
            <p><span class="syn-comment">$</span> <span class="syn-str">brew install</span> everydev1618/tap/vega</p>
            <p class="mt-1"><span class="syn-comment">$</span> <span class="syn-str">vega serve</span></p>
            <p class="text-zinc-500 mt-1">&#x25B6; Dashboard ready at http://localhost:3001</p>
          </div>
        </div>
      </div>
    </div>
  </section>

  <!-- Social proof / stats bar -->
  <section class="border-y border-zinc-800/50 bg-zinc-900/30">
    <div class="max-w-6xl mx-auto px-6 py-8 flex flex-wrap items-center justify-center gap-12 md:gap-20 text-center">
      <div>
        <p class="text-2xl font-bold text-white font-mono">850+</p>
        <p class="text-xs text-zinc-500 mt-1">App integrations via Composio</p>
      </div>
      <div>
        <p class="text-2xl font-bold text-white font-mono">Go + YAML</p>
        <p class="text-xs text-zinc-500 mt-1">Library or no-code DSL</p>
      </div>
      <div>
        <p class="text-2xl font-bold text-white font-mono">SQLite</p>
        <p class="text-xs text-zinc-500 mt-1">Zero-config persistence</p>
      </div>
      <div>
        <p class="text-2xl font-bold text-white font-mono">MCP</p>
        <p class="text-xs text-zinc-500 mt-1">Model Context Protocol native</p>
      </div>
    </div>
  </section>

  <!-- Features -->
  <section id="features" class="max-w-6xl mx-auto px-6 py-24">
    <div class="text-center mb-16">
      <p class="section-label">Features</p>
      <h2 class="text-3xl md:text-4xl font-bold text-white mb-4">Everything you need to orchestrate agents</h2>
      <p class="text-zinc-400 max-w-xl mx-auto">
        From a single agent to a full company of AI workers. Vega handles fault tolerance, team coordination, integrations, and observability.
      </p>
    </div>

    <div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-3 gap-5">
      {features.map(f => (
        <div class="feature-card">
          <div class={`mb-4 ${f.color}`} set:html={f.icon} />
          <h3 class="font-semibold text-white text-lg mb-2">{f.title}</h3>
          <p class="text-sm text-zinc-400 leading-relaxed">{f.desc}</p>
        </div>
      ))}
    </div>
  </section>

  <!-- How it works -->
  <section id="how-it-works" class="border-y border-zinc-800/50 bg-zinc-900/20">
    <div class="max-w-6xl mx-auto px-6 py-24">
      <div class="text-center mb-16">
        <p class="section-label">How it works</p>
        <h2 class="text-3xl md:text-4xl font-bold text-white mb-4">From idea to AI workforce in minutes</h2>
        <p class="text-zinc-400 max-w-xl mx-auto">
          No YAML required. Just talk to Iris and she'll build what you need.
        </p>
      </div>

      <div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-4 gap-6">
        {howItWorks.map(h => (
          <div class="relative">
            <span class="text-5xl font-bold font-mono text-zinc-800/80 mb-4 block">{h.step}</span>
            <h3 class="font-semibold text-white text-lg mb-2">{h.title}</h3>
            <p class="text-sm text-zinc-400 leading-relaxed">{h.desc}</p>
          </div>
        ))}
      </div>
    </div>
  </section>

  <!-- Quick start examples -->
  <section id="quickstart" class="max-w-6xl mx-auto px-6 py-24">
    <div class="text-center mb-16">
      <p class="section-label">Quick start</p>
      <h2 class="text-3xl md:text-4xl font-bold text-white mb-4">Three ways to use Vega</h2>
    </div>

    <div class="grid grid-cols-1 lg:grid-cols-3 gap-6">

      <!-- Chat -->
      <div class="gradient-border p-6">
        <div class="flex items-center gap-2 mb-4">
          <span class="text-violet-400">
            <svg class="w-5 h-5" fill="none" stroke="currentColor" stroke-width="1.5" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" d="M7.5 8.25h9m-9 3H12m-9.75 1.51c0 1.6 1.123 2.994 2.707 3.227 1.087.16 2.185.283 3.293.369V21l4.076-4.076a1.526 1.526 0 011.037-.443 48.282 48.282 0 005.68-.494c1.584-.233 2.707-1.626 2.707-3.228V6.741c0-1.602-1.123-2.995-2.707-3.228A48.394 48.394 0 0012 3c-2.392 0-4.744.175-7.043.513C3.373 3.746 2.25 5.14 2.25 6.741v6.018z" /></svg>
          </span>
          <h3 class="font-semibold text-white">Chat with Iris</h3>
        </div>
        <div class="code-block text-xs leading-relaxed">
          <p class="syn-comment"># Just talk</p>
          <p class="mt-2 text-zinc-300"><span class="text-violet-400">You:</span> I need a content team</p>
          <p class="text-zinc-300 mt-1"><span class="text-violet-400">You:</span> that can write blog posts</p>
          <p class="text-zinc-300 mt-1"><span class="text-violet-400">You:</span> and post to our Slack</p>
          <p class="mt-3 text-zinc-300"><span class="text-indigo-400">Iris:</span> On it. I'll have Hera</p>
          <p class="text-zinc-300">build that for you.</p>
          <p class="mt-3 text-zinc-300"><span class="text-amber-400">Hera:</span> Done, love. Meet your</p>
          <p class="text-zinc-300">team: Sofia (writer) and</p>
          <p class="text-zinc-300">Marcus (editor). Check</p>
          <p class="text-zinc-300">#content channel.</p>
        </div>
        <p class="text-xs text-zinc-500 mt-3">No code. No config files. Just describe what you need.</p>
      </div>

      <!-- YAML -->
      <div class="gradient-border p-6">
        <div class="flex items-center gap-2 mb-4">
          <span class="text-rose-400">
            <svg class="w-5 h-5" fill="none" stroke="currentColor" stroke-width="1.5" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" d="M19.5 14.25v-2.625a3.375 3.375 0 00-3.375-3.375h-1.5A1.125 1.125 0 0113.5 7.125v-1.5a3.375 3.375 0 00-3.375-3.375H8.25m2.25 0H5.625c-.621 0-1.125.504-1.125 1.125v17.25c0 .621.504 1.125 1.125 1.125h12.75c.621 0 1.125-.504 1.125-1.125V11.25a9 9 0 00-9-9z" /></svg>
          </span>
          <h3 class="font-semibold text-white">YAML DSL</h3>
        </div>
        <div class="code-block text-xs leading-relaxed">
          <p><span class="syn-key">name</span>: ContentTeam</p>
          <p class="mt-2"><span class="syn-key">settings</span>:</p>
          <p class="pl-4"><span class="syn-key">mcp</span>:</p>
          <p class="pl-6"><span class="syn-key">servers</span>:</p>
          <p class="pl-8">- <span class="syn-key">name</span>: <span class="syn-str">composio</span></p>
          <p class="mt-2"><span class="syn-key">agents</span>:</p>
          <p class="pl-4"><span class="syn-type">writer</span>:</p>
          <p class="pl-6"><span class="syn-key">model</span>: claude-sonnet-4-20250514</p>
          <p class="pl-6"><span class="syn-key">system</span>: <span class="syn-str">|</span></p>
          <p class="pl-8 syn-str">You write engaging blog posts.</p>
          <p class="pl-6"><span class="syn-key">tools</span>:</p>
          <p class="pl-8">- composio__slack_send</p>
        </div>
        <p class="text-xs text-zinc-500 mt-3">Declarative. Version-controlled. Reproducible.</p>
      </div>

      <!-- Go -->
      <div class="gradient-border p-6">
        <div class="flex items-center gap-2 mb-4">
          <span class="text-cyan-400">
            <svg class="w-5 h-5" fill="none" stroke="currentColor" stroke-width="1.5" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" d="M17.25 6.75L22.5 12l-5.25 5.25m-10.5 0L1.5 12l5.25-5.25m7.5-3l-4.5 16.5" /></svg>
          </span>
          <h3 class="font-semibold text-white">Go library</h3>
        </div>
        <div class="code-block text-xs leading-relaxed">
          <p><span class="syn-key">import</span> (</p>
          <p class="pl-4"><span class="syn-str">"github.com/everydev1618/govega"</span></p>
          <p class="pl-4"><span class="syn-str">"github.com/everydev1618/govega/llm"</span></p>
          <p>)</p>
          <p class="mt-2"><span class="syn-type">orch</span> := vega.<span class="syn-fn">NewOrchestrator</span>(</p>
          <p class="pl-4">vega.<span class="syn-fn">WithLLM</span>(llm.<span class="syn-fn">NewAnthropic</span>()),</p>
          <p>)</p>
          <p class="mt-2"><span class="syn-type">proc</span>, _ := orch.<span class="syn-fn">Spawn</span>(vega.Agent&#123;</p>
          <p class="pl-4">Name:  <span class="syn-str">"writer"</span>,</p>
          <p class="pl-4">Model: <span class="syn-str">"claude-sonnet-4-20250514"</span>,</p>
          <p>&#125;)</p>
          <p class="mt-2">resp, _ := proc.<span class="syn-fn">Send</span>(ctx, msg)</p>
        </div>
        <p class="text-xs text-zinc-500 mt-3">Full programmatic control. Embed in any Go app.</p>
      </div>
    </div>
  </section>

  <!-- Architecture -->
  <section class="border-y border-zinc-800/50 bg-zinc-900/20">
    <div class="max-w-6xl mx-auto px-6 py-24">
      <div class="text-center mb-16">
        <p class="section-label">Architecture</p>
        <h2 class="text-3xl md:text-4xl font-bold text-white mb-4">Built on proven patterns</h2>
        <p class="text-zinc-400 max-w-xl mx-auto">
          Vega applies Erlang's 40-year-old supervision model to AI agents.
          The result: agents that recover from failures automatically.
        </p>
      </div>

      <div class="grid grid-cols-1 md:grid-cols-3 gap-6 max-w-4xl mx-auto">
